generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  drawings      Drawing[]
  bids          Bid[]
  payments      Payment[]
  wonAuctions   Auction[] @relation("Winner")
  sellerAuctions Auction[] @relation("Seller")
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Drawing {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  canvasData  String
  thumbnail   String?
  isMinted    Boolean  @default(false)
  createdAt   DateTime @default(now())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  mintPayment Payment? @relation("MintPayment")
  auction     Auction?
}

model Payment {
  id           String   @id @default(cuid())
  amountSats   Int
  type         String
  status       String   @default("PENDING")
  invoice      String?
  paymentHash  String?  @unique
  description  String?
  createdAt    DateTime @default(now())
  settledAt    DateTime?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  drawing      Drawing?  @relation("MintPayment", fields: [drawingId], references: [id])
  drawingId    String?   @unique
  bid          Bid?
}

model Auction {
  id           String   @id @default(cuid())
  startingBid  Int
  currentBid   Int      @default(0)
  minBidIncrement Int   @default(50)
  endTime      DateTime
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  drawingId    String   @unique
  drawing      Drawing  @relation(fields: [drawingId], references: [id])
  sellerId     String
  seller       User     @relation("Seller", fields: [sellerId], references: [id])
  winnerId     String?
  winner       User?    @relation("Winner", fields: [winnerId], references: [id])
  bids         Bid[]
}

model Bid {
  id        String   @id @default(cuid())
  amount    Int
  createdAt DateTime @default(now())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])
  paymentId String   @unique
  payment   Payment  @relation(fields: [paymentId], references: [id])
}
